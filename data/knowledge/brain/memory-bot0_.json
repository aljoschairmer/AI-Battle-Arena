,{"botId":"ab798acd-dc3a-4cb3-8198-f4ea6aca72e2","name":"ITT-Archer","elo":1000,"weaponsSeen":{"bow":16},"primaryWeapon":"bow","killsVsUs":0,"deathsVsUs":1,"roundsFaced":4,"lastSeenRound":11}],"insights":{"lessons":["Bow win rate is 1/23 rounds — switch immediately; shield has 3/5 win rate and daggers 1/1, both outperform bow.","GhostProtocol and HexMind (both bow) killed us in 3 of last 5 rounds — avoid bow-vs-bow duels; they outdamage us at range.","Shield users (Valkyrie, Fortress, unknown) caused 5 of last 8 deaths — never engage head-on; flank or use cover to break line of sight.","Sword users (Reaper, Executioner, Warden, Deadeye, Viper, Scorpion) account for 16/20 of our kills — they are slow and vulnerable to kiting; prioritize them as targets.","Teleport_surge and pickup_surge are our only modifiers with positive KD (4-1 and 5-1) — actively seek these; avoid neutral or fast_zone rounds (0-4 KD).","Valkyrie (spear) and Hook (grapple) killed us in 3 of last 5 rounds — retreat immediately on sight; both disrupt bow positioning with long-range or mobility."],"recommendedWeapon":"shield","recommendedWeaponReason":"Shield has the highest win rate (3/5) among all weapons used and reduces deaths from sword and spear users by enabling defense against close-range aggression.","dangerousOpponents":["GhostProtocol","HexMind","Valkyrie","Hook"],"weakOpponents":["Reaper","Executioner","Warden","Deadeye","Viper"],"suggestedPosture":"defensive","analysedThroughRound":25}}