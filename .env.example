# ============================================================================
# AI Battle Arena Bot — configuration
# Copy to `.env` and fill in. Only ARENA_API_KEY is strictly required to fight;
# OpenRouter keys are only needed if you want the LLM strategy brain enabled.
# ============================================================================

# --- Process role ---------------------------------------------------------
# engine = real-time combat worker only
# brain  = LLM strategy worker only
# all    = run both in one process (requires BUS=memory, good for local dev)
ROLE=all

# --- Arena connection -----------------------------------------------------
ARENA_HTTP_BASE=https://arena.angel-serv.com
ARENA_WS_URL=wss://arena.angel-serv.com/ws/bot
# Origin sent on the WebSocket handshake (some proxies/CDNs only upgrade with one).
# Defaults to ARENA_HTTP_BASE; usually no need to change.
ARENA_WS_ORIGIN=https://arena.angel-serv.com
# Bot auth method. "message" (default) = direct-message auth: connect with no key,
# then send {"type":"auth","api_key":...}. This is the path that actually works.
# "query" = the documented ?key= path, which is currently BROKEN server-side (it
# returns HTTP 200 and refuses the WebSocket upgrade). Leave as "message".
ARENA_WS_AUTH=message
# Generate one with: npm run keygen   (or POST /api/v1/keys/generate)
ARENA_API_KEY=
# Run MULTIPLE bots in parallel: one key per bot, comma-separated. When set this
# takes precedence over ARENA_API_KEY; each bot gets its own name (BOT_NAME-1,
# BOT_NAME-2, ...), colour, LLM brain, and isolated bus scope.
# ARENA_API_KEYS=key1,key2,key3

# Bot identity (sent via select_loadout / config)
BOT_NAME=NeuralReaper
BOT_COLOR=#00d4ff

# --- Corporate proxy (Zscaler etc.) --------------------------------------
# If you're behind a TLS-inspecting proxy, WebSocket upgrades are often blocked
# (you'll see "Unexpected server response: 200" and endless reconnects). Set the
# proxy here so REST/LLM calls are routed and WS can be tunnelled. The real fix
# is usually to exempt arena.angel-serv.com from SSL inspection.
# HTTPS_PROXY=http://your-proxy:80
# NO_PROXY=localhost,127.0.0.1,redis

# --- Message bus ----------------------------------------------------------
# redis  = engine and brain are separate processes talking over Redis (prod)
# memory = single process, in-process bus (ROLE must be "all")
BUS=memory
REDIS_URL=redis://127.0.0.1:6379

# --- OpenRouter (LLM brain) ----------------------------------------------
# Leave OPENROUTER_API_KEY empty to run a pure deterministic bot (no LLM cost).
OPENROUTER_API_KEY=
OPENROUTER_BASE=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://arena.angel-serv.com
OPENROUTER_APP_NAME=ai-battle-arena-bot

# Per-agent models — any current OpenRouter model slug works. Strong model for
# the infrequent planning agents, fast/cheap model for the high-frequency
# tactician. Bump the planners to anthropic/claude-opus-4.8 for max strength.
OPENROUTER_MODEL_STRATEGIST=anthropic/claude-sonnet-4.6
OPENROUTER_MODEL_LOADOUT=anthropic/claude-sonnet-4.6
OPENROUTER_MODEL_TACTICIAN=anthropic/claude-haiku-4.5

# How often (ms) the tactician re-evaluates mid-round. The strategist + loadout
# agents run once per round at round_start.
TACTICIAN_INTERVAL_MS=2500
# Hard ceiling on any single LLM call before we fall back to deterministic logic.
LLM_TIMEOUT_MS=8000

# --- Logging --------------------------------------------------------------
# trace | debug | info | warn | error
LOG_LEVEL=info
# pretty = human-readable colors (dev); json = structured (prod)
LOG_FORMAT=pretty
